{
  "name": "blog-alexo",
  "type": "module",
  "version": "2.0.0",
  "description": "Alex's blog — Astro (AstroPaper) + TinaCMS",
  "license": "MIT",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "tinacms dev -c \"astro dev\"",
    "build": "tinacms build && astro check && astro build && pagefind --site dist && cp -r dist/pagefind public/",
    "build:local": "astro check && astro build && pagefind --site dist && cp -r dist/pagefind public/",
    "preview": "astro preview",
    "sync": "astro sync",
    "astro": "astro",
    "format:check": "prettier --check .",
    "format": "prettier --write .",
    "lint": "eslint ."
  },
  "dependencies": {
    "@astrojs/mdx": "^6.0.1",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.3",
    "astro": "^6.4.2",
    "dayjs": "^1.11.21",
    "js-yaml": "^4.2.0",
    "lodash.kebabcase": "^4.1.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "rehype-callouts": "^2.1.2",
    "remark-collapse": "^0.1.2",
    "remark-toc": "^9.0.0",
    "satori": "^0.26.0",
    "sharp": "^0.34.5",
    "slugify": "^1.6.9",
    "tailwindcss": "^4.3.0",
    "tinacms": "^3.9.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/markdown-remark": "^7.2.0",
    "@pagefind/default-ui": "^1.5.2",
    "@shikijs/transformers": "^4.1.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@tailwindcss/typography": "^0.5.19",
    "@tinacms/cli": "^2.4.0",
    "@types/js-yaml": "^4.0.9",
    "@types/lodash.kebabcase": "^4.1.9",
    "@typescript-eslint/parser": "^8.60.0",
    "eslint": "^10.4.1",
    "eslint-plugin-astro": "^1.7.0",
    "pagefind": "^1.5.2",
    "prettier": "3.8.3",
    "prettier-plugin-astro": "0.14.1",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "typescript": "^6.0.3",
    "zod": "^4.4.3"
  },
  "packageManager": "yarn@1.22.22"
}
