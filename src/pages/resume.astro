---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import Footer from "@/components/Footer.astro";
import config from "@/config";
---

<Layout
  title={`Resume | ${config.site.title}`}
  description="Alex Oladele's resume."
>
  <Header />
  <Breadcrumb />

  <main id="main-content" class="app-layout pb-8">
    <h1 class="text-2xl font-semibold sm:text-3xl">Resume</h1>
    <p class="mt-2 mb-8 italic">
      For the full details, check out the resume on Standard Resume.
    </p>

    <div class="text-center">
      <a
        href="https://standardresume.co/r/SRjXqZMiey97jseceSrVV"
        target="_blank"
        rel="noopener noreferrer"
        class="bg-accent text-background inline-block rounded-lg px-6 py-3 font-semibold transition-opacity hover:opacity-90"
      >
        View on Standard Resume
      </a>
    </div>
  </main>
  <Footer />
</Layout>
