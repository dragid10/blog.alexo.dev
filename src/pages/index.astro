---
import { getCollection } from "astro:content";
import { getRelativeLocaleUrl } from "astro:i18n";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Socials from "@/components/Socials.astro";
import Card from "@/components/Card.astro";
import LinkButton from "@/components/LinkButton.astro";
import CommitGraph from "@/components/CommitGraph.astro";
import { getSortedPosts } from "@/utils/getSortedPosts";
import { useTranslations } from "@/i18n";
import config from "@/config";

const { posts: postsConfig } = config;

const locale = Astro.currentLocale ?? config.site.lang;
const t = useTranslations(locale);

const posts = await getCollection("posts");
const sortedPosts = getSortedPosts(posts);
const recentPosts = sortedPosts.slice(0, postsConfig.perIndex);
const homePath = getRelativeLocaleUrl(locale, "");

const linkButtons = [
  { label: "Speaking", href: "/speaking/" },
  { label: "Projects", href: "/projects/" },
  { label: "Posts", href: "/posts/" },
  { label: "Resume", href: "/resume/" },
  { label: "\u{1F58B}️ Fountain Pen Collection", href: "https://pens.alexo.dev/" },
];
---

<Layout>
  <Header />
  <main
    id="main-content"
    data-layout="index"
    data-home-path={homePath}
    class="app-layout"
  >
    <section class="flex flex-col items-center pt-8 pb-6 text-center">
      <img
        src="/assets/uploads/headshot-web.jpeg"
        alt="Alex Oladele"
        width="160"
        height="160"
        class="mb-4 size-40 rounded-full object-cover"
        loading="eager"
      />
      <h1 class="text-3xl font-bold sm:text-4xl">Alex Oladele</h1>
      <p class="mt-1 text-lg opacity-75">Tech nerd on the internet!</p>

      <div class="mt-4">
        <Socials />
      </div>
    </section>

    <section class="border-border border-b pb-6">
      <p class="mx-auto max-w-lg text-center">
        Senior software engineer at Red Hat, working on Ansible Galaxy. I
        speak at conferences, build side projects, and write about
        programming, homelab adventures, and productivity experiments.
      </p>
    </section>

    <section class="border-border border-b py-6">
      <div class="mx-auto flex max-w-md flex-col gap-3">
        {
          linkButtons.map(({ label, href }) => (
            <a
              href={href}
              class="border-border bg-background hover:bg-muted/30 hover:border-accent/40 block rounded-lg border px-4 py-3 text-center font-medium transition-colors"
            >
              {label}
            </a>
          ))
        }
      </div>
    </section>

    {
      recentPosts.length > 0 && (
        <section id="recent-posts" class="border-border border-b py-6">
          <h2 class="text-2xl font-semibold tracking-wide">
            {t.home.recentPosts}
          </h2>
          <ul>
            {recentPosts.map(data => (
              <Card variant="h3" {...data} />
            ))}
          </ul>
          <div class="mt-4 text-center">
            <LinkButton href={getRelativeLocaleUrl(locale, "posts")}>
              {t.home.allPosts}
              <IconArrowRight class="inline-block rtl:-rotate-180" />
            </LinkButton>
          </div>
        </section>
      )
    }

    <section class="py-6">
      <CommitGraph />
    </section>
  </main>
  <Footer />
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const indexLayout = (document.querySelector("#main-content") as HTMLElement)
      ?.dataset;
    const baseRoot = import.meta.env.BASE_URL.replace(/\/?$/, "/");
    if (indexLayout?.layout) {
      sessionStorage.setItem("backUrl", indexLayout.homePath ?? baseRoot);
    }
  });
</script>
